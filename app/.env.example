# Copy to .env and fill in. On the server this lives at /opt/foundry/.env
AUTH_SECRET=            # long random string; sign-in sessions depend on it
ADMIN_USER=             # your login username (created on first DB init)
ADMIN_PASSWORD=         # your login password (created on first DB init)
DATABASE_PATH=data/foundry.db
PORT=3000               # adapter-node listens here; Caddy proxies to it
HOST=127.0.0.1

# --- Google Fit (optional, for daily steps) ---
# Create an OAuth 2.0 "Web application" client in Google Cloud (see DEPLOY.md),
# enable the Fitness API, and add <your-origin>/api/fit/callback as an authorized
# redirect URI. Leave blank to hide the "Connect Google Fit" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only needed if the auto-detected origin is wrong (e.g. behind an odd proxy).
# Must exactly match the redirect URI registered in the Google console.
# GOOGLE_REDIRECT_URI=https://foundry.example.com/api/fit/callback
